# ==============================================================================
# MySQL 备份从库配置文件
# ==============================================================================

# === 项目基础配置 ===
# 备份容器的名称标识 (例如: project_shop, project_blog)
# 每个备份实例必须不同
#--------改这里
PROJECT_NAME=demo_project

# === Slave Server ID (多从必填!) ===
# 每个 Slave 必须有唯一的 server-id
# Master 通常为 1，Slave 从 100 开始递增
# 示例: 第一个备份实例用 100，第二个用 101，第三个用 102...
#--------改这里
SERVER_ID=100

# === 1. 远程生产服务器 (SSH 连接信息) ===
# 生产服务器的公网 IP 地址
#--------改这里
SSH_HOST=1.2.3.4
# SSH 端口 (默认22)
SSH_PORT=22
# 登录用户 (通常是 root)
#--------改这里
SSH_USER=core
# 认证方式 (二选一):
# 方式A (推荐): 将私钥文件命名为 id_rsa 放在当前目录下，这里留空。
# 方式B (密码): 如果没有私钥，在此处填入密码。
SSH_PASSWORD=

# === 2. 远程生产数据库信息 (关键配置) ===
# 这里的端口必须对应生产服务器 docker-compose.yml 中映射到宿主机的端口
# 场景: 生产服务器上运行了多个项目，端口做了区分
# 示例: 生产端配置 ports: - "127.0.0.1:3306:3306" -> 这里填 3306
# 示例: 生产端配置 ports: - "127.0.0.1:3307:3306" -> 这里填 3307
#--------改这里----【看着生产服务器上的mysql开放的端口是什么对着改】
REMOTE_DB_PORT=3306

# === 3. 管理工具 (phpMyAdmin) ===
# 访问 http://localhost:8888 (每个项目需不同，如 8889, 8890...)
#--------改这里
PMA_WEB_PORT=8888

# === 4. new-api 服务端口 ===
# 仅在使用 docker-compose-with-newapi.yml 时需要
#--------改这里
NEW_API_PORT=3000

# === 5. 目标数据库 ===
# 指定需要备份的数据库名称 (只同步这一个库)
#--------改这里
TARGET_DB_NAME=new-api

# === 6. 复制账号 ===
# 生产库的复制账号 (需先在生产库创建，或直接使用 root)
MASTER_USER=root
#--------改这里
MASTER_PASSWORD=burncloud123456!qwf

# === 7. 本地备份库配置 ===
# 本地备份库的 Root 密码 (自行设置)
#--------改这里
MYSQL_ROOT_PASSWORD=burncloud123456!qwf

# ==============================================================================
# 多从数据库配置说明
# ==============================================================================
#
# 如果你有多个备份服务器需要从同一个 Master 同步数据，或者在一台备份服务器上
# 备份多个不同的数据库，需要注意以下几点：
#
# 1. SERVER_ID 必须唯一
#    - Master: 1
#    - Slave 1: 100
#    - Slave 2: 101
#    - Slave 3: 102
#    - ...
#
# 2. PROJECT_NAME 必须唯一
#    - 用于区分容器名称，如 backup_project_a, backup_project_b
#
# 3. PMA_WEB_PORT 必须唯一
#    - 每个 phpMyAdmin 需要不同的端口
#
# 4. NEW_API_PORT 必须唯一 (如果使用 new-api 服务)
#
# 示例 - 创建多个备份实例：
#
#   # 实例1: 备份 shop 数据库
#   cp -r template backup_shop
#   cd backup_shop
#   # 编辑 .env: PROJECT_NAME=shop, SERVER_ID=100, PMA_WEB_PORT=8888, TARGET_DB_NAME=shop
#
#   # 实例2: 备份 blog 数据库
#   cp -r template backup_blog
#   cd backup_blog
#   # 编辑 .env: PROJECT_NAME=blog, SERVER_ID=101, PMA_WEB_PORT=8889, TARGET_DB_NAME=blog
#
# ==============================================================================
